# Copy this file to `.env` and fill in your Jerry Goldman license details.
#
# When running the Docker image, mount this file so docker-entrypoint.sh can
# load it before starting the server, e.g.:
#   docker run -v $(pwd)/.env:/tgstation/.env:ro ...
# or, with docker-compose:
#   services:
#     roguetown:
#       env_file: .env

# Base URL of the goldman-roguetown service.
GOLDMAN_API_URL=https://goldman-roguetown.onrender.com

# The API key issued by Jerry Goldman.
GOLDMAN_API_KEY=
