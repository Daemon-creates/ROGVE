# Copy this file to `.env` and fill in your Jerry Goldman license details.
#
# This file is used in two ways:
#   1. Locally (e.g. running fetch_goldman_files.sh directly, or via the VS
#      Code "Build All" tasks / F5 launch) — the script automatically loads
#      a `.env` file that sits next to it, i.e. this repo's root `.env`.
#   2. In the standalone Docker image (see the root Dockerfile) — mount this
#      file to /tgstation/.env so docker-entrypoint.sh's call to
#      fetch_goldman_files.sh can load it, e.g.:
#        docker run -v $(pwd)/.env:/tgstation/.env:ro ...
#      or, with docker-compose:
#        services:
#          roguetown:
#            env_file: .env
#
# NOTE: if you are using tools/DockerTestServer's docker-compose setup
# instead, use tools/DockerTestServer/example.env (copied to
# tools/DockerTestServer/.env) rather than this file.

# Base URL of the goldman-roguetown service.
GOLDMAN_API_URL=https://goldman-roguetown.onrender.com

# The API key issued by Jerry Goldman.
GOLDMAN_API_KEY=
